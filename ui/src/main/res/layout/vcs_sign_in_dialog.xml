<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/vcs_dialog_background"
    android:orientation="vertical"
    android:padding="22dp">

    <ImageView
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:contentDescription="@string/app_name"
        android:src="@mipmap/ic_launcher" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/vcs_sign_in"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/email_input"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/vcs_dialog_input_background"
        android:hint="@string/vcs_sign_in_email"
        android:imeOptions="actionNext"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="14dp"
        android:singleLine="true"
        android:textColor="#FFFFFF"
        android:textColorHint="#8EA2AE"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/password_input"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/vcs_dialog_input_background"
        android:hint="@string/vcs_sign_in_password"
        android:imeOptions="actionDone"
        android:inputType="textPassword"
        android:paddingHorizontal="14dp"
        android:singleLine="true"
        android:textColor="#FFFFFF"
        android:textColorHint="#8EA2AE"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/cancel_button"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/vcs_dialog_secondary_button"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="@android:string/cancel"
            android:textColor="#E5F2F7"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sign_in_button"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/vcs_dialog_primary_button"
            android:clickable="true"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:drawableStart="@drawable/ic_account"
            android:drawableTint="#02110F"
            android:text="@string/vcs_sign_in"
            android:textColor="#02110F"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
