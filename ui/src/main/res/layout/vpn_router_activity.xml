<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dashboard_gradient">

    <ImageView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:alpha="0.075"
        android:contentDescription="@null"
        android:src="@mipmap/ic_launcher" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="28dp"
            android:paddingBottom="96dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_marginBottom="16dp"
                android:text="@string/vcs_vpn_router_page_title"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/router_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/fastest_button_background"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_wifi"
                    app:tint="#FFFFFF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/vcs_vpn_router_title"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/router_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/vcs_vpn_router_checking"
                        android:textColor="#AFC0CC"
                        android:textSize="13sp"
                        tools:text="On: tun0 routes hotspot traffic via swlan0" />

                    <TextView
                        android:id="@+id/router_uplink_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/vcs_vpn_router_uplink_checking"
                        android:textColor="#AFC0CC"
                        android:textSize="13sp"
                        tools:text="Uplink: mobile data rmnet_data0" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/fastest_button_background"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_server"
                        app:tint="#AFC0CC" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/vcs_vpn_router_router_protection"
                        android:textColor="#AFC0CC"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/router_protection_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/vcs_vpn_router_checking"
                    android:textColor="#AFC0CC"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/vcs_vpn_router_router_protection_detail"
                    android:textColor="#7D8B99"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/fastest_button_background"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_web"
                        app:tint="#AFC0CC" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/vcs_vpn_router_dns"
                        android:textColor="#AFC0CC"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/router_dns_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/router_dns_copy_tunnel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3B82F6"
                        android:text="@string/vcs_vpn_router_dns_copy_tunnel"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/router_dns_cloudflare"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3B82F6"
                        android:text="@string/vcs_vpn_router_dns_cloudflare"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/router_dns_google"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3B82F6"
                        android:text="@string/vcs_vpn_router_dns_google"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/router_dns_quad9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3B82F6"
                        android:text="@string/vcs_vpn_router_dns_quad9"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/router_dns_family"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3B82F6"
                        android:text="@string/vcs_vpn_router_dns_family"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                </RadioGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/vcs_vpn_router_dns_detail"
                    android:textColor="#7D8B99"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_marginTop="14dp"
                android:text="@string/vcs_vpn_router_page_summary"
                android:textColor="#7D8B99"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
