<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="com.wireguard.android.backend.Tunnel.State" />
        <variable name="fragment" type="com.wireguard.android.fragment.TunnelDetailFragment" />
        <variable name="tunnel" type="com.wireguard.android.model.ObservableTunnel" />
        <variable name="config" type="com.wireguard.config.Config" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/dashboard_gradient">

        <ImageView
            android:id="@+id/detail_background_logo"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:alpha="0.075"
            android:contentDescription="@null"
            android:src="@mipmap/ic_launcher" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="28dp"
                android:paddingBottom="96dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fastest_button_background"
                    android:clipToOutline="true"
                    android:elevation="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="12dp"
                        android:background="@{tunnel.state == State.UP ? @drawable/status_dot_connected : @drawable/status_dot_disconnected}" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tunnel_name_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@{tunnel.name}"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="managed-access-server" />

                        <TextView
                            android:id="@+id/status_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@{tunnel.state == State.UP ? @string/status_vpn_live : @string/status_disconnected}"
                            android:textColor="@{tunnel.state == State.UP ? @color/vpn_connected : @color/vpn_disconnected}"
                            android:textSize="13sp"
                            tools:text="Connected" />
                    </LinearLayout>

                    <com.wireguard.android.widget.ToggleSwitch
                        android:id="@+id/tunnel_detail_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:checked="@{tunnel.state == State.UP}"
                        app:onBeforeCheckedChanged="@{fragment::setTunnelState}"
                        tools:checked="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/public_identity_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:elevation="5dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_web"
                            app:tint="#AFC0CC" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_public_identity"
                            android:textColor="#AFC0CC"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_tap_recheck"
                            android:textColor="#7FA8B8"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/public_identity_ip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:text="@string/stat_checking"
                        android:textColor="#FFFFFF"
                        android:textIsSelectable="true"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="51.77.67.19" />

                    <TextView
                        android:id="@+id/public_identity_ipv6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:textColor="#AFC0CC"
                        android:textIsSelectable="true"
                        android:textSize="12sp"
                        tools:text="2a01:4f8:c17::1" />

                    <TextView
                        android:id="@+id/public_identity_geo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="#AFC0CC"
                        android:textSize="13sp"
                        tools:text="🇸🇰 Slovakia · Bratislava" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/fastest_button_background"
                    android:clipToOutline="true"
                    android:elevation="5dp"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_server"
                            app:tint="#8899AA" />

                        <TextView
                            android:id="@+id/server_ip_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_public_ip"
                            android:textColor="#AFC0CC"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/server_ip_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:text="@string/stat_no_data"
                        android:textColor="#FFFFFF"
                        android:textIsSelectable="true"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="51.77.67.19" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dns_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:elevation="5dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_server"
                            app:tint="#AFC0CC" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_dns"
                            android:textColor="#AFC0CC"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dns_test_link"
                            android:textColor="#7FA8B8"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/dns_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:text="@string/stat_no_data"
                        android:textColor="#FFFFFF"
                        android:textIsSelectable="true"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="10.76.0.1" />

                    <TextView
                        android:id="@+id/dns_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="#86EFAC"
                        android:textSize="12sp"
                        tools:text="Protected — queries tunnel through the VPN" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/web_terminal_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/fastest_button_background"
                    android:clipToOutline="true"
                    android:elevation="5dp"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_web"
                            app:tint="#8899AA" />

                        <View
                            android:id="@+id/web_terminal_health_dot"
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:layout_marginEnd="7dp"
                            android:background="@drawable/status_dot_disconnected"
                            tools:background="@drawable/status_dot_connected" />

                        <TextView
                            android:id="@+id/web_terminal_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/web_terminal"
                            android:textColor="#AFC0CC"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/web_terminal_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="3dp"
                        android:textColor="#FFFFFF"
                        android:textIsSelectable="true"
                        android:textSize="12sp"
                        tools:text="http://10.76.1.1:7681/" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/web_terminal_copy"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:minWidth="92dp"
                            android:text="@string/copy"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/web_terminal_open"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:minWidth="92dp"
                            android:text="@string/open_terminal"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#E6050A12"
            android:elevation="8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/home_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/fastest_button_background"
                android:clickable="true"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:singleLine="true"
                android:text="@string/vcs_home_title"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/secure_browser_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/fastest_button_background"
                android:clickable="true"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:singleLine="true"
                android:text="@string/vcs_home_secure_browser"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</layout>
