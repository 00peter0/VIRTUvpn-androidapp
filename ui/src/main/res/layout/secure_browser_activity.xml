<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dashboard_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#071018"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/url_input"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/fastest_button_background"
                    android:hint="@string/vcs_secure_browser_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8899AA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/go_button"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="@string/vcs_secure_browser_go"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/save_page_button"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="@string/vcs_secure_browser_save"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/quick_links_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/find_toggle_button"
                        android:layout_width="72dp"
                        android:layout_height="36dp"
                        android:background="@drawable/fastest_button_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/vcs_secure_browser_find"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_zoom_down_button"
                        android:layout_width="48dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/fastest_button_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/vcs_secure_browser_zoom_down"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_zoom_label"
                        android:layout_width="60dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:textColor="#AFC0CC"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_zoom_up_button"
                        android:layout_width="48dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/fastest_button_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/vcs_secure_browser_zoom_up"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/desktop_mode_button"
                        android:layout_width="104dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/fastest_button_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/find_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <EditText
                    android:id="@+id/find_input"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/fastest_button_background"
                    android:hint="@string/vcs_secure_browser_find_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8899AA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/find_match_label"
                    android:layout_width="72dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:textColor="#AFC0CC"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/find_prev_button"
                    android:layout_width="42dp"
                    android:layout_height="40dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/vcs_secure_browser_find_prev"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/find_next_button"
                    android:layout_width="42dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/vcs_secure_browser_find_next"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/find_close_button"
                    android:layout_width="42dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/vcs_secure_browser_find_close"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/egress_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/vcs_secure_browser_egress_checking"
                android:textColor="#7FE6A2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/security_badge_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/https_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="@drawable/fastest_button_background"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:singleLine="true"
                    android:text="@string/vcs_secure_browser_https_waiting"
                    android:textColor="#AFC0CC"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tracker_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/fastest_button_background"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:singleLine="true"
                    android:text="@string/vcs_secure_browser_trackers_blocked_zero"
                    android:textColor="#7FE6A2"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/browser_view_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/browser_refresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:enabled="false">

                <WebView
                    android:id="@+id/secure_webview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <ProgressBar
                android:id="@+id/page_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressTint="#7FE6A2"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/vpn_blocker"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/vcs_secure_browser_blocked"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/blocker_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/vcs_secure_browser_blocked_detail"
                    android:textColor="#AFC0CC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/pair_router_button"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="18dp"
                    android:text="@string/vcs_secure_browser_pair_router"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/forget_routers_button"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="@string/vcs_secure_browser_forget_routers"
                    android:textColor="#AFC0CC"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/browser_navigation_pad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="18dp"
                android:background="@drawable/fastest_button_background"
                android:clipToOutline="true"
                android:elevation="8dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="6dp">

                <TextView
                    android:id="@+id/browser_reload_button"
                    android:layout_width="82dp"
                    android:layout_height="40dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:singleLine="true"
                    android:text="@string/vcs_secure_browser_reload"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/browser_back_button"
                    android:layout_width="82dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:singleLine="true"
                    android:text="@string/vcs_secure_browser_back"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/browser_forward_button"
                    android:layout_width="82dp"
                    android:layout_height="40dp"
                    android:background="@drawable/fastest_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:singleLine="true"
                    android:text="@string/vcs_secure_browser_forward"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
